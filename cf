function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  const btns = document.querySelectorAll('.nav-btn');
  const map = {home:0,teams:1,andrew:2,donuts:3};
  btns[map[id]].classList.add('active');
}

function showTeam(key) {
  const t = teams[key];
  document.getElementById('team-list').style.display = 'none';
  const detail = document.getElementById('team-detail');
  detail.style.display = 'block';
  const membersHtml = t.members.length ? t.members.map(m => `<div class="member-row"><span class="member-name">${m.split(' — ')[0]}</span><span class="member-amount">${m.split(' — ')[1] || ''}</span></div>`).join('') : '<p style="font-size:14px;color:var(--color-text-secondary)">View the full team on the official page.</p>';
  const progressHtml = t.pct > 0 ? `<div class="progress-bar"><div class="progress-fill" style="width:${t.pct}%"></div></div>` : '';
  detail.querySelector('#team-detail-content').innerHTML = `
    <div class="card">
      <h2 style="font-size:18px">${t.name}</h2>
      ${t.raised ? `<div style="font-size:20px;font-weight:500;color:#c8102e;margin-bottom:4px">${t.raised} raised${t.goal ? ` of ${t.goal} goal` : ''}</div>` : ''}
      ${progressHtml}
      <div style="margin-top:1rem;display:flex;gap:10px;flex-wrap:wrap">
        <a class="donate-btn" href="${t.url}" target="_blank">View on CFF</a>
        <a class="donate-btn" href="${t.joinUrl}" target="_blank" style="background:none;border:0.5px solid #c8102e;color:#c8102e">Join team</a>
      </div>
    </div>
    ${t.members.length ? `<div class="card"><h2>Team members</h2>${membersHtml}</div>` : ''}
  `;
}

function backToTeams() {
  document.getElementById('team-list').style.display = 'block';
  document.getElementById('team-detail').style.display = 'none';
}
</script>
