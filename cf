.card h2 { font-size: 16px; font-weight: 500; margin-bottom: 1rem; }
.grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 1.5rem; }
.metric { background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 1rem; }
.metric .label { font-size: 13px; color: var(--color-text-secondary); margin-bottom: 4px; }
.metric .value { font-size: 22px; font-weight: 500; }
.metric .value.red { color: #c8102e; }
.team-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1rem 1.25rem; cursor: pointer; transition: border-color 0.15s; }
